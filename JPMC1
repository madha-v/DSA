#include<iostream>
using namespace std;
int reverse(int n)
{
    int rem=0, rev=0;
    while(n!=0)
    {
        rem=n%10;
        rev=10*rev+rem;
        n=n/10;
    }
    return rev;
}

bool ispallindrone(int n)
{
    return n==reverse(n);
}
int main()
{
    int n;
    cout<<"enter the value of number";
    cin>>n;
    int i=0;
    while(true)
    {
        int n1=reverse(n)+n;
        i++;
        
        if(ispallindrone(n1))
        {
            cout<<i<<" "<<n1;
            break;
        }
      n=n1;
    }
         return 0;
}
