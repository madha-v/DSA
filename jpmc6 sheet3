#include <iostream>
#include<vector>
#include<cmath>
using namespace std;
#include<algorithm>
int dist(pair<int,int>a , pair<int,int>b)
{
      return sqrt(pow(a.first-b.first,2)+pow(a.second-b.second,2));
}
       
int main(){
    int n;
    cin>>n;
    vector<pair<int, int>>cities(n);
    for(int i=0;i<n;i++)
    cin>>cities[i].first>>cities[i].second;
    int src, desti;
    cin>>src>>desti;
    
    vector<pair<int, int>>t;
    for(int i=0;i<n;i++)
    {
        if(i!=src && i!=desti)
        {
            int d=dist(cities[src],cities[i]);
            t.push_back({d,i});
        }
        
    }
    sort(t.begin(),t.end());
    cout<<"path"<<" "<<src<<" ";
    
    for(auto &x:t)
    {
        int i=x.second;
        if(dist(cities[i],cities[src])<dist(cities[src],cities[desti])){
            cout<<i<<" ";
        }
    }
    cout<<desti;
}
           
